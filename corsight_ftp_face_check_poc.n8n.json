      "id": "16",
      "name": "Analyze Crop Quality",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1060,
        -240
      ]
    },
    {
      "parameters": {
        "jsCode": "const analyze = $json;\nconst ctx = $item(0).$node['Check Detections + Select Best Detection'].json;\n\nif (analyze.statusCode < 200 || analyze.statusCode >= 300) {\n  return [{ json: { ...ctx, status: 'error', error_stage: 'analyze', error_http: analyze.statusCode, error_body: analyze.body } }];\n}\n\nconst body = analyze.body || {};\nconst validFace = body.valid_face === true;\n\nif (!validFace) {\n  return [{ json: { ...ctx, status: 'invalid_face', valid_face: false, analyze_raw: body } }];\n}\n\nreturn [{ json: { ...ctx, status: 'valid_face', valid_face: true, analyze_raw: body } }];"
      },
      "id": "17",
      "name": "Check Face Validity",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1280,
        -240
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.status}}",
              "operation": "equal",
              "value2": "valid_face"
            }
          ]
        }
      },
      "id": "18",
      "name": "Route After Analyze",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1500,
        -240
      ]
    },
    {
      "parameters": {
        "jsCode": "const ctx = $json;\nconst references = [\n  { reference_id: 'ref_1', person_name: 'Pessoa de Interesse', face_base64: 'BASE64_REFERENCE_1' },\n  { reference_id: 'ref_2', person_name: 'Pessoa de Interesse', face_base64: 'BASE64_REFERENCE_2' }\n];\n\nreturn references.map((ref) => ({\n  json: {\n    ...ctx,\n    reference_id: ref.reference_id,\n    person_name: ref.person_name,\n    reference_face_base64: ref.face_base64\n  }\n}));"
      },
      "id": "19",
      "name": "Load Reference Faces",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1720,
        -360
      ],
      "notes": "Coleção simples de referências em Base64 para POC. Substituir placeholders BASE64_REFERENCE_X.",
      "notesInFlow": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.CORSIGHT_BASE_URL_POI}}/poi_db/face/compare",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$json.token}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"face_ref\": {\n    \"image_payload\": {\n      \"img\": \"{{$json.reference_face_base64}}\",\n      \"detect\": false,\n      \"use_detector_lms\": true,\n      \"fail_on_multiple_faces\": true\n    }\n  },\n  \"face_test\": {\n    \"image_payload\": {\n      \"img\": \"{{$json.crop_base64}}\",\n      \"detect\": false,\n      \"use_detector_lms\": true,\n      \"fail_on_multiple_faces\": true\n    }\n  },\n  \"convert_to_conf\": true\n}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
      "id": "20",
      "name": "Compare Against References",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1940,
        -360
      ]
    },
    {
      "parameters": {
        "jsCode": "const results = [];\nfor (let i = 0; i < items.length; i++) {\n  const cmp = items[i].json;\n  const ctx = $item(i).$node['Load Reference Faces'].json;\n\n  if (cmp.statusCode < 200 || cmp.statusCode >= 300) {\n    return [{\n      json: {\n        ...ctx,\n        status: 'error',\n        error_stage: 'compare',\n        error_http: cmp.statusCode,\n        error_body: cmp.body,\n      }\n    }];\n  }\n\n  const body = cmp.body || {};\n  const score = Number(body.match_confidence ?? body.score ?? 0);\n\n  results.push({\n    reference_id: ctx.reference_id,\n    person_name: ctx.person_name,\n    match_confidence: score,\n    raw: body\n  });\n}\n\nresults.sort((a, b) => b.match_confidence - a.match_confidence);\nconst best = results[0] || null;\nconst root = $item(0).$node['Load Reference Faces'].json;\n\nlet classification = 'no_match';\nif (best && best.match_confidence >= 85) classification = 'strong_match';\nelse if (best && best.match_confidence >= 75) classification = 'manual_review';\n\nreturn [{\n  json: {\n    ...root,\n    status: 'classified',\n    compared_references: results.length,\n    best_score: best ? best.match_confidence : 0,\n    best_reference_id: best ? best.reference_id : null,\n    classification,\n    compare_results: results\n  }\n}];"
      },
      "id": "21",
      "name": "Aggregate Scores + Classify Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2160,
        -360
      ]
