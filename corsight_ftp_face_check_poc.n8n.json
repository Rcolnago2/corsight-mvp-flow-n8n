    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.CORSIGHT_BASE_URL_POI}}/poi_db/face/analyze",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$json.token}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"image_payload\": {\n    \"img\": \"{{$json.crop_base64}}\",\n    \"detect\": false,\n    \"use_detector_lms\": true,\n    \"fail_on_multiple_faces\": true\n  },\n  \"get_signature_payload\": false\n}",
        "options": {
