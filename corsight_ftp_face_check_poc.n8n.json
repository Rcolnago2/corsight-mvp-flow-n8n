      "parameters": {
        "jsCode": "return [{\n  json: {\n    file_name: $json.file_name,\n    source_path: $json.source_path,\n    detection_score: $json.detection_score ?? null,\n    valid_face: $json.valid_face ?? null,\n    best_score: $json.best_score ?? null,\n    best_reference_id: $json.best_reference_id ?? null,\n    classification: $json.classification ?? $json.status,\n    status: $json.status,\n    error_stage: $json.error_stage ?? null,\n    error_http: $json.error_http ?? null,\n    processed_at: new Date().toISOString()\n  }\n}];"
      },
