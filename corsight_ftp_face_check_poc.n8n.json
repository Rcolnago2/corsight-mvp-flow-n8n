    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.CORSIGHT_BASE_URL_AUTH}}/login",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"username\": \"{{$env.CORSIGHT_USERNAME}}\",\n  \"password\": \"{{$env.CORSIGHT_PASSWORD}}\"\n}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
      "id": "4",
      "name": "Corsight Login",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -1160,
        -40
      ],
      "notes": "Autentica no Corsight Auth e obtém Bearer token.",
      "notesInFlow": true
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.statusCode}}",
              "operation": "equal",
              "value2": 200
            }
          ]
        }
      },
      "id": "5",
      "name": "Check Login Success",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        -960,
        -40
      ]
    },
    {
      "parameters": {
        "jsCode": "throw new Error(`Corsight login failed. HTTP ${$json.statusCode}. Body: ${JSON.stringify($json.body || {})}`);"
      },
      "id": "6",
      "name": "Stop - Login Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -740,
        120
      ],
      "notes": "Falha de autenticação deve parar o workflow com erro explícito.",
      "notesInFlow": true
    },
    {
      "parameters": {
        "operation": "list",
        "path": "={{$env.FTP_INPUT_PATH}}",
        "options": {
          "host": "={{$env.FTP_HOST}}",
          "port": "={{Number($env.FTP_PORT || 21)}}",
          "user": "={{$env.FTP_USER}}",
          "password": "={{$env.FTP_PASSWORD}}"
        }
      },
      "id": "7",
      "name": "List FTP Files",
      "type": "n8n-nodes-base.ftp",
      "typeVersion": 1,
      "position": [
        -740,
        -120
      ],
      "notes": "Lista arquivos do diretório de entrada no FTP.",
      "notesInFlow": true
    },
    {
      "parameters": {
        "jsCode": "const token = $item(0).$node['Corsight Login'].json.body?.access_token || $item(0).$node['Corsight Login'].json.body?.token;\nif (!token) throw new Error('Token não encontrado na resposta de login.');\n\nconst inputPath = $env.FTP_INPUT_PATH || '/input';\nconst out = [];\n\nfor (const item of items) {\n  const row = item.json;\n  const name = row.name || row.file || row.fileName || '';\n  const isDir = row.type === 'd' || row.isDirectory === true || row.directory === true;\n  if (isDir) continue;\n\n  const lower = name.toLowerCase();\n  if (!lower.endsWith('.jpg') && !lower.endsWith('.jpeg') && !lower.endsWith('.png')) continue;\n\n  out.push({\n    json: {\n      token,\n      file_name: name,\n      source_path: `${inputPath.replace(/\\/$/, '')}/${name}`,\n      listing_meta: row\n    }\n  });\n}\n\nreturn out;"
      },
      "id": "8",
      "name": "Filter Image Files + Attach Token",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -520,
        -120
      ],
      "notes": "Filtra somente .jpg/.jpeg/.png, ignora diretórios e anexa token em cada item.",
      "notesInFlow": true
    },
    {
      "parameters": {
        "batchSize": 1
      },
      "id": "9",
      "name": "Process Each FTP Image",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        -300,
        -120
      ]
    },
    {
      "parameters": {
        "operation": "download",
        "path": "={{$json.source_path}}",
        "binaryPropertyName": "image",
        "options": {
          "host": "={{$env.FTP_HOST}}",
          "port": "={{Number($env.FTP_PORT || 21)}}",
          "user": "={{$env.FTP_USER}}",
          "password": "={{$env.FTP_PASSWORD}}"
        }
      },
      "id": "10",
      "name": "Download FTP Image",
      "type": "n8n-nodes-base.ftp",
      "typeVersion": 1,
      "position": [
        -100,
        -120
      ]
    },
    {
      "parameters": {
        "jsCode": "const bin = $binary.image;\nif (!bin?.data) throw new Error('Imagem binária não encontrada em $binary.image');\n\nconst imageBase64 = bin.data;\n\nreturn [{\n  json: {\n    ...$json,\n    image_base64: imageBase64\n  }\n}];"
      },
      "id": "11",
      "name": "Convert Image To Base64",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        120,
        -120
      ],
      "notes": "No n8n, binário já fica em base64 no campo binary.data.",
      "notesInFlow": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.CORSIGHT_BASE_URL_POI}}/poi_db/face/detect",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$json.token}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"get_crops\": true,\n  \"imgs\": [\n    {\n      \"img\": \"{{$json.image_base64}}\"\n    }\n  ]\n}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
      "id": "12",
      "name": "Detect Face",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        340,
        -120
      ]
    },
    {
      "parameters": {
        "jsCode": "const detect = $json;\nconst ctx = $item(0).$node['Convert Image To Base64'].json;\n\nconst statusCode = detect.statusCode;\nconst body = detect.body || {};\nif (statusCode < 200 || statusCode >= 300) {\n  return [{ json: { ...ctx, status: 'error', error_stage: 'detect', error_http: statusCode, error_body: body } }];\n}\n\nconst faces = body.faces || body.detections || body.results || [];\nif (!Array.isArray(faces) || faces.length === 0) {\n  return [{ json: { ...ctx, status: 'no_face_detected', detect_raw: body } }];\n}\n\nfunction bboxArea(face) {\n  const bb = face.bbox || face.bounding_box || {};\n  const w = Math.max(0, (bb.w ?? bb.width ?? 0));\n  const h = Math.max(0, (bb.h ?? bb.height ?? 0));\n  return w * h;\n}\n\nconst ranked = [...faces].sort((a, b) => {\n  const dsA = a.detection_score ?? a.score ?? 0;\n  const dsB = b.detection_score ?? b.score ?? 0;\n  if (dsB !== dsA) return dsB - dsA;\n  return bboxArea(b) - bboxArea(a);\n});\n\nconst best = ranked[0];\nconst cropBase64 = best.crop_img || best.crop || best.face_crop || best.img_crop;\nif (!cropBase64) {\n  return [{ json: { ...ctx, status: 'error', error_stage: 'select_detection', error_body: body, error_message: 'Crop não encontrado na melhor detecção' } }];\n}\n\nreturn [{\n  json: {\n    ...ctx,\n    status: 'face_detected',\n    detect_raw: body,\n    detection_score: best.detection_score ?? best.score ?? null,\n    selected_face: best,\n    crop_base64: cropBase64\n  }\n}];"
      },
      "id": "13",
      "name": "Check Detections + Select Best Detection",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
